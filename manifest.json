{
  "vendor": "yourvendor",
  "name": "vtex-shopify-integration",
  "version": "1.0.0",
  "title": "VTEX-Shopify-3PL Order & Fulfillment Bridge",
  "description": "Pushes VTEX orders into Shopify and routes them into a third-party fulfillment app via Shopify's fulfillment orders API, then syncs tracking and invoicing back into VTEX OMS.",
  "builders": {
    "react": "3.x",
    "messages": "1.x",
    "docs": "0.x",
    "admin": "0.x",
    "node": "6.x",
    "graphql": "2.x"
  },
  "categories": [],
  "dependencies": {
    "vtex.styleguide": "9.x"
  },
  "scripts": {
    "prereleasy": "bash lint.sh"
  },
  "credentialType": "absolute",
  "policies": [
    {
      "name": "ADMIN_DS"
    },
    {
      "name": "OMSViewer"
    },
    {
      "name": "POWER_USER_DS"
    },
    {
      "name": "AdminPortal"
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "portal.vtexcommercestable.com.br",
        "path": "/api/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "api.vtex.com",
        "path": "/dataentities/*"
      }
    },
    {
      "name": "outbound-access",
      "attrs": {
        "host": "*",
        "path": "*"
      }
    },
    {
      "name": "colossus-fire-event"
    },
    {
      "name": "colossus-write-logs"
    }
  ],
  "settingsSchema": {
    "title": "Shopify ERP Integration",
    "type": "object",
    "bindingBounded": false,
    "properties": {
      "Shopify_Store_Name": {
        "title": "Shopify Store Name",
        "description": "Store Name must be entered without any hyphens or spaces",
        "type": "string"
      },
      "Shopify_Store_URL": {
        "title": "Shopify Store URL",
        "description": "",
        "type": "string"
      },
      "Shopify_Admin_API_access_token": {
        "title": "Shopify Admin API Access Token",
        "description": "",
        "type": "string"
      },
      "Shopify_Location_ID": {
        "title": "Shopify Location ID",
        "description": "Inventory values will only be taken from a specific location if its ID is provided.",
        "type": "string"
      }
    }
  }
}
